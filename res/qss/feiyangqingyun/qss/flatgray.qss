/*TextColor:#57595B*/
/*PanelColor:#FFFFFF*/
/*BorderColor:#B6B6B6*/
/*NormalColorStart:#E4E4E4*/
/*NormalColorEnd:#E4E4E4*/
/*DarkColorStart:#F6F6F6*/
/*DarkColorEnd:#F6F6F6*/
/*HighColor:#575959*/


/* Color tokens (from your input)
 *  TextColor:        #57595B
 *  PanelColor:       #FFFFFF
 *  BorderColor:      #B6B6B6
 *  NormalColorStart: #E4E4E4
 *  NormalColorEnd:   #E4E4E4
 *  DarkColorStart:   #F6F6F6
 *  DarkColorEnd:     #F6F6F6
 *  HighColor:        #575959
 */

/* Base checkbox text and spacing */
QCheckBox {
    color: #57595B;               /* TextColor */
    spacing: 6px;
    padding: 2px 4px;
    background: transparent;
}

/* Indicator size */
QCheckBox::indicator {
    width: 13px;
    height: 13px;
    border-radius: 3px;
    margin: 0 4px 0 0;
}

/* Unchecked (normal) - subtle flat/light background matching NormalColorStart/End */
QCheckBox::indicator:unchecked {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #E4E4E4, stop:1 #E4E4E4); /* NormalColorStart/End */
    border: 1px solid #B6B6B6;   /* BorderColor */
}

/* Hover over the indicator - slightly lighter using DarkColorStart/End */
QCheckBox::indicator:unchecked:hover {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #F6F6F6, stop:1 #F6F6F6); /* DarkColorStart/End as hover highlight */
    border: 1px solid #AFAFAF;
}

/* Pressed state - subtle inset look */
QCheckBox::indicator:unchecked:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #E4E4E4, stop:1 #DDDDDD);
    border: 1px solid #9f9f9f;
    padding: 1px;
}

/* Checked - fill with high color (HighColor) and keep subtle border */
QCheckBox::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #575959, stop:1 #454546); /* HighColor and a slightly darker stop */
    border: 1px solid #B6B6B6;
}

/* Ensure no external image overrides our styling */
QCheckBox::indicator:checked {
    image: none;
}

/* Disabled state - muted colors */
QCheckBox:disabled {
    color: #A0A0A0; /* dimmed text */
}

QCheckBox::indicator:disabled {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #F0F0F0, stop:1 #E8E8E8);
    border: 1px solid #D0D0D0;
    opacity: 0.65;
}


/* Focus ring around the whole checkbox when focused (subtle) */
QCheckBox:focus {
    outline: none;
}


/* Larger hit area when using the check text label */
QCheckBox::indicator, QCheckBox {
    min-height: 18px;
}



/* Base radio text and spacing */
QRadioButton {
    color: #57595B;               /* TextColor */
    spacing: 6px;
    padding: 2px 4px;
    background: transparent;
}

/* Indicator size (circular instead of square) */
QRadioButton::indicator {
    width: 13px;
    height: 13px;
    border-radius: 7px; /* makes it circular */
    margin: 0 4px 0 0;
}

/* Unchecked */
QRadioButton::indicator:unchecked {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #E4E4E4, stop:1 #E4E4E4);
    border: 1px solid #B6B6B6;
}

/* Hover */
QRadioButton::indicator:unchecked:hover {
    background: #F6F6F6;
    border: 1px solid #AFAFAF;
}

/* Pressed */
QRadioButton::indicator:unchecked:pressed {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #E4E4E4, stop:1 #DDDDDD);
    border: 1px solid #9f9f9f;
}

/* Checked state outer circle */
QRadioButton::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #575959, stop:1 #454546); /* HighColor */
    border: 1px solid #B6B6B6;
}

/* Inner dot (this is the "radio check") */
QRadioButton::indicator:checked {
    image: none;
    position: relative;
}

/* Disabled */
QRadioButton:disabled {
    color: #A0A0A0;
}

QRadioButton::indicator:disabled {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #F0F0F0, stop:1 #E8E8E8);
    border: 1px solid #D0D0D0;
    opacity: 0.65;
}

/* Focus */
QRadioButton:focus {
    outline: none;
}
/* Hit area consistency */
QRadioButton::indicator, QRadioButton {
    min-height: 18px;
}


/* Base menu item */
QMenu {
    color: #57595B;
    background: #FFFFFF;
    border: 1px solid #D0D0D0;
    padding: 4px;
}

/* Menu item spacing */
QMenu::item {
    padding: 4px 24px 4px 28px; /* space for indicator on the left */
    background: transparent;
}

/* Hover */
QMenu::item:selected {
    background: #F6F6F6;
    color: #57595B;
}

/* Pressed */
QMenu::item:pressed {
    background: #E4E4E4;
}

/* ========================= */
/* CHECKBOX INDICATOR (menu) */
/* ========================= */

QMenu::indicator {
    width: 13px;
    height: 13px;

    border-radius: 3px;
    margin-left: 6px;
}

/* Unchecked */
QMenu::indicator:unchecked {
    background: #E4E4E4;
    border: 1px solid #B6B6B6;
}

/* Hover (when item is hovered) */
QMenu::indicator:unchecked:selected {
    background: #F6F6F6;
    border: 1px solid #AFAFAF;
}

/* Checked */
QMenu::indicator:checked {
    background: qlineargradient(x1:0, y1:0, x2:0, y2:1,
                                stop:0 #575959, stop:1 #454546);
    border: 1px solid #B6B6B6;

    /* checkmark */
    image: url("data:image/svg+xml;utf8,\
<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 13 13'>\
<polyline points='2,7 5,10 11,3' fill='none' stroke='%23FFFFFF' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' />\
</svg>");
    background-repeat: no-repeat;
    background-position: center;
}

/* Pressed checked */
QMenu::indicator:checked:pressed {
    background: #454546;
}

/* Disabled */
QMenu::item:disabled {
    color: #A0A0A0;
}

QMenu::indicator:disabled {
    background: #F0F0F0;
    border: 1px solid #D0D0D0;
    opacity: 0.6;
}

QMenu::indicator:disabled:checked {
    image: url("data:image/svg+xml;utf8,\
<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 13 13'>\
<polyline points='2,7 5,10 11,3' fill='none' stroke='%23999999' stroke-width='2' stroke-linecap='round' stroke-linejoin='round' />\
</svg>");
}

/* Focus/keyboard navigation */
QMenu::item:selected {
    outline: none;
}